{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "browser_specific_settings": {
    "gecko": {
      "id": "rabbit-gatekeeper@ylwu",
      "strict_min_version": "115.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "version": "0.1.0",
  "description": "__MSG_appDescription__",
  "default_locale": "en",
  "permissions": ["storage"],
  "icons": {
    "16": "assets/rabbiticon16.png",
    "48": "assets/rabbiticon48.png",
    "128": "assets/rabbiticon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "__MSG_appName__",
    "default_icon": {
      "16": "assets/rabbiticon16.png",
      "48": "assets/rabbiticon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["shared.js", "content.js"],
      "css": ["content.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
